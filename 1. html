<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kinetic Interface Showcase & Specification</title>
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&family=JetBrains+Mono:wght@400;500;700&family=Syne:wght@700;800&family=Outfit:wght@400;500;600;700;900&display=swap" rel="stylesheet">
  
  <!-- GSAP -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  
  <!-- Marked.js for Markdown Parsing -->
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  
  <!-- KaTeX for Math Equation Rendering -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css">
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/contrib/auto-render.min.js"></script>
  
  <!-- PrismJS for Syntax Highlighting -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" rel="stylesheet" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-typescript.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-tsx.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-css.min.js"></script>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Outfit', 'Inter', 'sans-serif'],
            mono: ['JetBrains Mono', 'monospace'],
            display: ['Syne', 'sans-serif'],
          },
          colors: {
            darkBg: '#070708',
            panelBg: '#0b0b0e',
            borderSubtle: 'rgba(255, 255, 255, 0.05)',
            borderHighlight: 'rgba(59, 130, 246, 0.3)',
            accentBlue: '#3b82f6',
            accentCyan: '#00f5ff',
            accentPurple: '#8b5cf6',
          }
        }
      }
    }
  </script>

  <style>
    /* Procedural Noise Overlay */
    .noise-overlay {
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    }

    /* Glow border beam animation */
    .border-beam-container {
      position: relative;
      border-radius: inherit;
    }
    .border-beam {
      pointer-events: none;
      position: absolute;
      inset: 0;
      border-radius: inherit;
      border: 1.5px solid transparent;
      mask-clip: padding-box, border-box;
      mask-composite: intersect;
      -webkit-mask-composite: source-in; /* standard: intersect */
      mask-image: linear-gradient(transparent, transparent), linear-gradient(white, white);
      -webkit-mask-image: linear-gradient(transparent, transparent), linear-gradient(white, white);
    }
    .border-beam-trail {
      position: absolute;
      aspect-ratio: 1;
      width: var(--size, 120px);
      background: linear-gradient(to right, var(--color-from, #3b82f6), var(--color-to, #8b5cf6));
      offset-path: rect(0% auto auto 0% round 100%);
      animation: beam var(--duration, 8s) linear infinite;
    }
    @keyframes beam {
      100% {
        offset-distance: 100%;
      }
    }

    /* Markdown styling overrides */
    .prose h1, .prose h2, .prose h3, .prose h4 {
      font-family: 'Syne', 'Outfit', sans-serif;
      color: #ffffff;
      font-weight: 800;
      letter-spacing: -0.02em;
    }
    .prose h2 {
      border-bottom: 1px solid rgba(255,255,255,0.05);
      padding-bottom: 0.5rem;
      margin-top: 2rem;
    }
    .prose p {
      color: #9ca3af;
      line-height: 1.7;
      font-size: 0.95rem;
      margin-bottom: 1.25rem;
    }
    .prose code {
      font-family: 'JetBrains Mono', monospace;
      background-color: rgba(255, 255, 255, 0.04);
      padding: 0.2rem 0.4rem;
      border-radius: 0.25rem;
      color: #e5e7eb;
      font-size: 0.85em;
    }
    .prose pre {
      background-color: #0b0b0e !important;
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 0.75rem;
      padding: 1.25rem;
      margin: 1.5rem 0;
      overflow-x: auto;
    }
    .prose pre code {
      background-color: transparent;
      padding: 0;
      border-radius: 0;
      font-size: 0.85rem;
      color: inherit;
    }
    .prose table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
      font-size: 0.9rem;
    }
    .prose th {
      background-color: rgba(255,255,255,0.02);
      border-bottom: 2px solid rgba(255,255,255,0.08);
      color: #ffffff;
      font-weight: 600;
      text-align: left;
      padding: 0.75rem;
    }
    .prose td {
      border-bottom: 1px solid rgba(255,255,255,0.04);
      padding: 0.75rem;
      color: #9ca3af;
    }
    .prose strong {
      color: #ffffff;
    }
    .prose ul, .prose ol {
      color: #9ca3af;
      margin-left: 1.5rem;
      margin-bottom: 1.25rem;
      list-style-type: decimal;
    }
    .prose ul {
      list-style-type: disc;
    }
    .prose li {
      margin-bottom: 0.5rem;
    }
    
    /* Scrollbar */
    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    ::-webkit-scrollbar-track {
      background: #070708;
    }
    ::-webkit-scrollbar-thumb {
      background: #1f2937;
      border-radius: 3px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #374151;
    }
  </style>
</head>
<body class="bg-darkBg text-gray-100 min-h-screen relative overflow-x-hidden font-sans selection:bg-blue-500/20 selection:text-white">

  <!-- Interactive Flowfield Background Canvas -->
  <canvas id="flowfield-canvas" class="fixed inset-0 pointer-events-none z-0"></canvas>
  
  <!-- Subtle Grain Overlay -->
  <div class="noise-overlay fixed inset-0 pointer-events-none z-40 opacity-[0.03] mix-blend-overlay"></div>

  <!-- Custom Dynamic Cursor -->
  <div id="custom-cursor-ring" class="fixed top-0 left-0 w-8 h-8 rounded-full border-[1.5px] border-accentBlue pointer-events-none z-[9999] mix-blend-difference hidden md:block" style="transform: translate(-50%, -50%); transform-origin: center;"></div>
  <div id="custom-cursor-dot" class="fixed top-0 left-0 w-1.5 h-1.5 rounded-full bg-accentCyan pointer-events-none z-[9999] mix-blend-difference hidden md:block" style="transform: translate(-50%, -50%);"></div>

  <!-- Main Container -->
  <div class="relative z-10 flex flex-col min-h-screen">
    
    <!-- Top Glass Header -->
    <header class="sticky top-0 w-full bg-darkBg/60 backdrop-blur-md border-b border-borderSubtle py-4 px-6 z-30 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-2.5 h-2.5 rounded-full bg-accentCyan animate-ping"></div>
        <span class="font-display font-black text-sm uppercase tracking-wider text-white">TEAMIAI // KINETIC INTERFACE</span>
      </div>
      
      <!-- Tab Controls -->
      <div class="flex items-center gap-1 bg-[#101014] border border-borderSubtle rounded-lg p-0.5">
        <button id="tab-manuscript" onclick="switchTab('manuscript')" class="px-4 py-1.5 rounded-md text-xs font-medium transition-all duration-300 bg-accentBlue/10 border border-accentBlue/20 text-white">
          Specification Document
        </button>
        <button id="tab-sandbox" onclick="switchTab('sandbox')" class="px-4 py-1.5 rounded-md text-xs font-medium transition-all duration-300 text-gray-400 hover:text-white">
          Interactive Sandbox
        </button>
      </div>
      
      <div class="text-[10px] font-mono text-gray-500 uppercase tracking-widest hidden sm:block">
        BUILD v1.0.2
      </div>
    </header>

    <!-- CONTENT WRAPPER -->
    <main class="flex-1 w-full max-w-6xl mx-auto px-6 py-10 relative">

      <!-- ================= MANUSCRIPT TAB ================= -->
      <div id="panel-manuscript" class="space-y-12 transition-all duration-300">
        
        <!-- Interactive Mask Reveal Hero Block -->
        <div id="hero-bounds" class="relative w-full min-h-[400px] md:min-h-[480px] flex items-center justify-center overflow-hidden bg-[#0a0a0c] border border-borderSubtle rounded-3xl p-8 md:p-12 cursor-none select-none">
          
          <!-- Mask Reveal Layer -->
          <div class="absolute inset-0 select-none pointer-events-none" style="mask-image: url(#substrate-reveal-mask); -webkit-mask-image: url(#substrate-reveal-mask);">
            <div class="absolute inset-0 bg-gradient-to-br from-[#0a0a0f] to-[#0c182c]"></div>
            <!-- Procedural grid coordinates -->
            <div class="absolute inset-0 opacity-20 bg-[linear-gradient(to_right,#00f5ff_1px,transparent_1px),linear-gradient(to_bottom,#00f5ff_1px,transparent_1px)] bg-[size:30px_30px]"></div>
            <!-- Spinning elements -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-[380px] h-[380px] md:w-[450px] md:h-[450px] rounded-full border border-accentCyan/20 animate-pulse flex items-center justify-center">
                <div class="w-[260px] h-[260px] md:w-[300px] md:h-[300px] rounded-full border-2 border-dashed border-accentCyan/10 animate-spin" style="animation-duration: 30s;"></div>
              </div>
            </div>
            <!-- Inside mask text -->
            <div class="absolute inset-0 flex flex-col justify-center items-center text-center px-4">
              <span class="text-[10px] font-mono uppercase tracking-[0.4em] text-accentCyan mb-4">
                Substrate Architecture Active
              </span>
              <h1 class="text-3xl md:text-5xl font-black tracking-tight text-white max-w-4xl leading-tight font-display">
                LATENT ARCHITECTURES: INTERROGATING THE SILICON SUBSTRATE BENEATH
              </h1>
            </div>
          </div>

          <!-- Outside static text -->
          <div class="relative pointer-events-none z-10 flex flex-col justify-center items-center text-center px-4 mix-blend-screen">
            <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
              System Overview Mapping
            </span>
            <h1 class="text-3xl md:text-5xl font-black tracking-tight text-gray-500 max-w-4xl leading-tight opacity-40 font-display">
              LATENT ARCHITECTURES: INTERROGATING THE SILICON SUBSTRATE BENEATH
            </h1>
          </div>

          <!-- SVG definitions for clip mask -->
          <svg class="absolute w-0 h-0" aria-hidden="true">
            <defs>
              <mask id="substrate-reveal-mask">
                <rect width="100%" height="100%" fill="black" />
                <circle id="path-mask" cx="-300" cy="-300" r="0" fill="white" />
              </mask>
            </defs>
          </svg>
        </div>

        <!-- Rendered Markdown Container -->
        <article id="markdown-container" class="prose prose-invert max-w-none bg-[#0a0a0c]/60 border border-borderSubtle rounded-3xl p-8 md:p-12 shadow-2xl relative overflow-hidden">
          <!-- Animated Border Beam for Manuscript -->
          <div class="border-beam">
            <div class="border-beam-trail" style="--size: 200px; --duration: 12s; --color-from: #3b82f6; --color-to: #00f5ff;"></div>
          </div>
          <div id="markdown-rendered-content">
            <div class="flex items-center justify-center py-20">
              <div class="w-8 h-8 border-2 border-accentCyan border-t-transparent rounded-full animate-spin"></div>
            </div>
          </div>
        </article>

      </div>

      <!-- ================= SANDBOX TAB ================= -->
      <div id="panel-sandbox" class="hidden space-y-8 transition-all duration-300">
        
        <!-- Header -->
        <div class="flex flex-col gap-2">
          <h2 class="text-2xl font-display font-black tracking-tight text-white">INTERACTIVE COMPONENT SANDBOX</h2>
          <p class="text-xs text-gray-400 font-mono">Tweak, optimize, and interact with the reconstruction components in real-time.</p>
        </div>

        <!-- Grid of Demos -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
          
          <!-- Left Column: Controls (40%) -->
          <div class="lg:col-span-5 flex flex-col gap-6">
            
            <!-- Component selector tabs -->
            <div class="bg-[#101014] border border-borderSubtle rounded-xl p-1.5 flex flex-col gap-1.5">
              <button onclick="selectSandboxComp('flowfield')" id="btn-comp-flowfield" class="w-full text-left px-4 py-3 rounded-lg border text-xs font-semibold flex items-center justify-between transition-all bg-accentBlue/10 border-accentBlue/20 text-white">
                <span>1. Flow Field Background</span>
                <span class="text-[9px] bg-accentBlue/20 text-accentBlue px-2 py-0.5 rounded font-mono uppercase">CANVAS</span>
              </button>
              <button onclick="selectSandboxComp('cursor')" id="btn-comp-cursor" class="w-full text-left px-4 py-3 rounded-lg border text-xs font-semibold flex items-center justify-between transition-all border-borderSubtle text-gray-400 hover:text-white hover:bg-white/5">
                <span>2. Velocity-Stretched Cursor</span>
                <span class="text-[9px] bg-accentPurple/25 text-accentPurple px-2 py-0.5 rounded font-mono uppercase">GSAP</span>
              </button>
              <button onclick="selectSandboxComp('mask')" id="btn-comp-mask" class="w-full text-left px-4 py-3 rounded-lg border text-xs font-semibold flex items-center justify-between transition-all border-borderSubtle text-gray-400 hover:text-white hover:bg-white/5">
                <span>3. Substrate Reveal Mask</span>
                <span class="text-[9px] bg-accentCyan/20 text-accentCyan px-2 py-0.5 rounded font-mono uppercase">SVG MASK</span>
              </button>
              <button onclick="selectSandboxComp('beam')" id="btn-comp-beam" class="w-full text-left px-4 py-3 rounded-lg border text-xs font-semibold flex items-center justify-between transition-all border-borderSubtle text-gray-400 hover:text-white hover:bg-white/5">
                <span>4. CSS Border Beams</span>
                <span class="text-[9px] bg-emerald-500/20 text-emerald-400 px-2 py-0.5 rounded font-mono uppercase">CSS</span>
              </button>
            </div>

            <!-- Parameters panel -->
            <div class="bg-[#0a0a0c] border border-borderSubtle rounded-2xl p-6 space-y-6">
              <h3 class="text-xs font-mono font-bold text-white uppercase border-b border-borderSubtle pb-2">Tuning Parameters</h3>
              
              <!-- Flowfield controls -->
              <div id="controls-flowfield" class="space-y-4">
                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-gray-400">Grid Spacing</span>
                    <span id="val-spacing" class="text-white">60px</span>
                  </div>
                  <input type="range" min="30" max="150" value="60" oninput="updateFlowfieldParam('spacing', this.value)" class="w-full h-1 bg-[#101014] rounded-lg appearance-none cursor-pointer accent-accentBlue">
                </div>

                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-gray-400">Pull Radius</span>
                    <span id="val-radius" class="text-white">300px</span>
                  </div>
                  <input type="range" min="100" max="600" value="300" oninput="updateFlowfieldParam('radius', this.value)" class="w-full h-1 bg-[#101014] rounded-lg appearance-none cursor-pointer accent-accentBlue">
                </div>

                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-gray-400">Gravity Coefficient</span>
                    <span id="val-gravity" class="text-white">0.18</span>
                  </div>
                  <input type="range" min="0.05" max="0.5" step="0.01" value="0.18" oninput="updateFlowfieldParam('gravity', this.value)" class="w-full h-1 bg-[#101014] rounded-lg appearance-none cursor-pointer accent-accentBlue">
                </div>

                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-gray-400">Elastic Dampening</span>
                    <span id="val-damping" class="text-white">0.85</span>
                  </div>
                  <input type="range" min="0.5" max="0.98" step="0.01" value="0.85" oninput="updateFlowfieldParam('damping', this.value)" class="w-full h-1 bg-[#101014] rounded-lg appearance-none cursor-pointer accent-accentBlue">
                </div>

                <button onclick="resetFlowfieldGrid()" class="w-full py-2 bg-accentBlue/10 hover:bg-accentBlue/20 border border-accentBlue/30 text-accentBlue rounded-lg text-xs font-mono font-medium transition-all">
                  Re-initialize Canvas Grid
                </button>
              </div>

              <!-- Cursor controls -->
              <div id="controls-cursor" class="space-y-4 hidden">
                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-gray-400">Stretch Scale</span>
                    <span id="val-c-stretch" class="text-white">1.0</span>
                  </div>
                  <input type="range" min="0.5" max="3" step="0.1" value="1.0" oninput="updateCursorParam('stretch', this.value)" class="w-full h-1 bg-[#101014] rounded-lg appearance-none cursor-pointer accent-accentPurple">
                </div>

                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-gray-400">Lag Duration (GSAP)</span>
                    <span id="val-c-duration" class="text-white">0.3s</span>
                  </div>
                  <input type="range" min="0.05" max="1" step="0.05" value="0.3" oninput="updateCursorParam('duration', this.value)" class="w-full h-1 bg-[#101014] rounded-lg appearance-none cursor-pointer accent-accentPurple">
                </div>

                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-gray-400">Color Palette</span>
                  </div>
                  <div class="grid grid-cols-3 gap-2">
                    <button onclick="updateCursorColor('#3b82f6')" class="py-1.5 border border-accentBlue bg-[#3b82f6]/10 text-white rounded text-[10px] font-mono">Blue</button>
                    <button onclick="updateCursorColor('#a855f7')" class="py-1.5 border border-transparent bg-purple-500/10 text-purple-400 hover:border-purple-500/50 rounded text-[10px] font-mono">Purple</button>
                    <button onclick="updateCursorColor('#00f5ff')" class="py-1.5 border border-transparent bg-cyan-500/10 text-cyan-400 hover:border-cyan-500/50 rounded text-[10px] font-mono">Cyan</button>
                  </div>
                </div>
              </div>

              <!-- Mask controls -->
              <div id="controls-mask" class="space-y-4 hidden">
                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-gray-400">Aperture Radius</span>
                    <span id="val-m-radius" class="text-white">160px</span>
                  </div>
                  <input type="range" min="50" max="300" value="160" oninput="updateMaskParam('radius', this.value)" class="w-full h-1 bg-[#101014] rounded-lg appearance-none cursor-pointer accent-accentCyan">
                </div>

                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-gray-400">Grid Substrate Color</span>
                  </div>
                  <div class="grid grid-cols-2 gap-2">
                    <button onclick="updateMaskSubstrateColor('rgba(0, 245, 255, 0.25)')" class="py-1.5 border border-accentCyan bg-cyan-500/10 text-white rounded text-[10px] font-mono">Cyan Grid</button>
                    <button onclick="updateMaskSubstrateColor('rgba(239, 68, 68, 0.25)')" class="py-1.5 border border-transparent bg-red-500/10 text-red-400 hover:border-red-500/50 rounded text-[10px] font-mono">Red Alert Grid</button>
                  </div>
                </div>
              </div>

              <!-- Beam controls -->
              <div id="controls-beam" class="space-y-4 hidden">
                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-gray-400">Beam Size</span>
                    <span id="val-b-size" class="text-white">120px</span>
                  </div>
                  <input type="range" min="50" max="300" value="120" oninput="updateBeamParam('size', this.value)" class="w-full h-1 bg-[#101014] rounded-lg appearance-none cursor-pointer accent-emerald-500">
                </div>

                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-gray-400">Speed (Duration)</span>
                    <span id="val-b-duration" class="text-white">8s</span>
                  </div>
                  <input type="range" min="2" max="20" value="8" oninput="updateBeamParam('duration', this.value)" class="w-full h-1 bg-[#101014] rounded-lg appearance-none cursor-pointer accent-emerald-500">
                </div>

                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between text-xs font-mono">
                    <span class="text-gray-400">Colors</span>
                  </div>
                  <div class="grid grid-cols-2 gap-2">
                    <button onclick="updateBeamColors('#3b82f6', '#8b5cf6')" class="py-1.5 border border-accentBlue bg-blue-500/10 text-white rounded text-[10px] font-mono">Blue-Purple</button>
                    <button onclick="updateBeamColors('#10b981', '#00f5ff')" class="py-1.5 border border-transparent bg-emerald-500/10 text-emerald-400 hover:border-emerald-500/50 rounded text-[10px] font-mono">Green-Cyan</button>
                  </div>
                </div>
              </div>

            </div>

          </div>

          <!-- Right Column: Live Sandbox Preview (60%) -->
          <div class="lg:col-span-7 flex flex-col h-full min-h-[500px]">
            <div class="h-full bg-[#0a0a0c] border border-borderSubtle rounded-2xl flex flex-col shadow-2xl relative overflow-hidden min-h-[500px]">
              
              <!-- Simulated Header -->
              <div class="border-b border-borderSubtle bg-[#101014]/50 px-4 py-3 flex items-center justify-between select-none">
                <div class="flex items-center gap-1.5">
                  <div class="w-2.5 h-2.5 rounded-full bg-red-500/30" />
                  <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/30" />
                  <div class="w-2.5 h-2.5 rounded-full bg-green-500/30" />
                  <span class="text-[10px] font-mono text-gray-500 ml-3">Component Preview Sandbox</span>
                </div>
              </div>

              <!-- Preview Area -->
              <div id="sandbox-preview-container" class="flex-1 relative flex items-center justify-center p-8 bg-darkBg overflow-hidden">
                
                <!-- 1. Flow Field background preview -->
                <div id="sandbox-ff-preview" class="absolute inset-0 flex items-center justify-center pointer-events-none select-none z-10">
                  <div class="text-center max-w-sm bg-panelBg/80 border border-white/5 p-6 rounded-2xl backdrop-blur-md">
                    <span class="text-[10px] font-mono text-accentBlue block mb-2">DYNAMIC GRAVITY WELL ACTIVE</span>
                    <p class="text-xs text-gray-400">Move your mouse cursor across the preview window to see the underlying grid dynamically warp around coordinates.</p>
                  </div>
                </div>

                <!-- 2. Cursor Sandbox Preview -->
                <div id="sandbox-cursor-preview" class="hidden flex-col items-center justify-center text-center max-w-md bg-panelBg/80 border border-white/5 p-6 rounded-2xl backdrop-blur-md z-10 gap-3">
                  <span class="text-[10px] font-mono text-accentPurple block">VELOCITY-STRETCHED CURSOR TESTING</span>
                  <p class="text-xs text-gray-400">Move the mouse quickly inside this area. Notice how the outer ring stretches along the travel direction and contracts along the perpendicular axis to maintain area volume.</p>
                  <div class="w-full bg-[#101014] p-3 rounded-lg border border-borderSubtle font-mono text-[10px] text-gray-300 text-left space-y-1">
                    <div>Velocity (Scalar): <span id="telemetry-v" class="text-accentPurple">0.0</span></div>
                    <div>Angle (Degree): <span id="telemetry-a" class="text-accentPurple">0.0°</span></div>
                  </div>
                </div>

                <!-- 3. Mask Sandbox Preview -->
                <div id="sandbox-mask-preview" class="hidden w-full h-full relative flex items-center justify-center">
                  <!-- Embeded a mini Mask Reveal -->
                  <div id="sandbox-hero" class="relative w-full h-[320px] flex items-center justify-center overflow-hidden bg-[#070708] border border-white/5 rounded-2xl p-6 cursor-none select-none">
                    <div class="absolute inset-0 select-none pointer-events-none" style="mask-image: url(#sb-reveal-mask); -webkit-mask-image: url(#sb-reveal-mask);">
                      <div class="absolute inset-0 bg-gradient-to-br from-[#0c101c] to-[#0c182c]"></div>
                      <div id="sb-grid-lines" class="absolute inset-0 opacity-30 bg-[linear-gradient(to_right,#00f5ff_1px,transparent_1px),linear-gradient(to_bottom,#00f5ff_1px,transparent_1px)] bg-[size:20px_20px]"></div>
                      <div class="absolute inset-0 flex items-center justify-center">
                        <div class="w-[200px] h-[200px] rounded-full border border-accentCyan/30 animate-pulse"></div>
                      </div>
                      <div class="absolute inset-0 flex items-center justify-center text-center">
                        <h2 class="text-xl font-black text-white font-display uppercase tracking-widest">SUBSTRATE ACTIVATE</h2>
                      </div>
                    </div>
                    
                    <div class="relative pointer-events-none z-10 flex items-center justify-center text-center mix-blend-screen">
                      <h2 class="text-xl font-black text-gray-500 opacity-30 font-display uppercase tracking-widest">SUBSTRATE ACTIVATE</h2>
                    </div>

                    <svg class="absolute w-0 h-0" aria-hidden="true">
                      <defs>
                        <mask id="sb-reveal-mask">
                          <rect width="100%" height="100%" fill="black" />
                          <circle id="sb-path-mask" cx="-300" cy="-300" r="0" fill="white" />
                        </mask>
                      </defs>
                    </svg>
                  </div>
                </div>

                <!-- 4. Border Beam Sandbox Preview -->
                <div id="sandbox-beam-preview" class="hidden w-full max-w-sm">
                  <div class="relative bg-panelBg border border-white/5 rounded-2xl p-8 text-center flex flex-col justify-center gap-4 min-h-[220px]">
                    
                    <!-- Dynamic Border Beam Component -->
                    <div id="sb-border-beam" class="border-beam">
                      <div id="sb-beam-trail" class="border-beam-trail" style="--size: 120px; --duration: 8s; --color-from: #3b82f6; --color-to: #8b5cf6;"></div>
                    </div>

                    <span class="text-[10px] font-mono text-emerald-400 uppercase tracking-widest block">Border Beam Light Path</span>
                    <h3 class="text-lg font-bold text-white">Gradient Tracking</h3>
                    <p class="text-xs text-gray-400">A hardware-accelerated laser beam flows along the custom card boundaries using CSS offset-paths, avoiding CPU thrashing.</p>
                  </div>
                </div>

              </div>

            </div>
          </div>

        </div>

      </div>

    </main>

    <!-- Footer -->
    <footer class="border-t border-borderSubtle py-6 bg-darkBg text-center text-xs text-gray-500 font-mono mt-auto relative z-10">
      <div class="container mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
        <span>&copy; 2026 TeamIAI. Systemic UI/UX Specification.</span>
        <div class="flex items-center gap-6">
          <a href="#" onclick="switchTab('manuscript'); return false;" class="hover:text-accentCyan transition-colors">Spec Sheet</a>
          <a href="#" onclick="switchTab('sandbox'); return false;" class="hover:text-accentCyan transition-colors">Sandbox Run</a>
        </div>
      </div>
    </footer>
  </div>

  <!-- Javascript Logic for Interactive Elements -->
  <script>
    // Decoded Base64 Markdown Text
    const encodedMarkdown = "";
    const decodedMarkdown = atob(encodedMarkdown);
    
    // Configure Marked Options
    marked.setOptions({
      gfm: true,
      breaks: true,
      headerIds: true,
      mangle: false,
    });
    
    // Render Markdown on load
    document.addEventListener("DOMContentLoaded", () => {
      const container = document.getElementById("markdown-rendered-content");
      if (container && decodedMarkdown) {
        container.innerHTML = marked.parse(decodedMarkdown);
        // Trigger Katex rendering
        renderMathInElement(container, {
          delimiters: [
            {left: "$$", right: "$$", display: true},
            {left: "$", right: "$", display: false}
          ],
          throwOnError : false
        });
        // Trigger PrismJS highlighting
        Prism.highlightAllUnder(container);
      }
    });

    // Tab Switching
    function switchTab(tab) {
      const manuscriptBtn = document.getElementById("tab-manuscript");
      const sandboxBtn = document.getElementById("tab-sandbox");
      const manuscriptPanel = document.getElementById("panel-manuscript");
      const sandboxPanel = document.getElementById("panel-sandbox");
      
      if (tab === 'manuscript') {
        manuscriptBtn.className = "px-4 py-1.5 rounded-md text-xs font-medium transition-all duration-300 bg-accentBlue/10 border border-accentBlue/20 text-white";
        sandboxBtn.className = "px-4 py-1.5 rounded-md text-xs font-medium transition-all duration-300 text-gray-400 hover:text-white";
        manuscriptPanel.classList.remove("hidden");
        sandboxPanel.classList.add("hidden");
      } else {
        sandboxBtn.className = "px-4 py-1.5 rounded-md text-xs font-medium transition-all duration-300 bg-accentBlue/10 border border-accentBlue/20 text-white";
        manuscriptBtn.className = "px-4 py-1.5 rounded-md text-xs font-medium transition-all duration-300 text-gray-400 hover:text-white";
        sandboxPanel.classList.remove("hidden");
        manuscriptPanel.classList.add("hidden");
      }
    }

    // Sandbox Component Selector
    function selectSandboxComp(comp) {
      const buttons = ['flowfield', 'cursor', 'mask', 'beam'];
      buttons.forEach(b => {
        const btn = document.getElementById("btn-comp-" + b);
        const ctrl = document.getElementById("controls-" + b);
        const preview = document.getElementById("sandbox-" + b + "-preview");
        
        if (b === comp) {
          btn.className = "w-full text-left px-4 py-3 rounded-lg border text-xs font-semibold flex items-center justify-between transition-all bg-accentBlue/10 border-accentBlue/20 text-white";
          ctrl.classList.remove("hidden");
          preview.classList.remove("hidden");
        } else {
          btn.className = "w-full text-left px-4 py-3 rounded-lg border text-xs font-semibold flex items-center justify-between transition-all border-borderSubtle text-gray-400 hover:text-white hover:bg-white/5";
          ctrl.classList.add("hidden");
          preview.classList.add("hidden");
        }
      });
    }

    // ==========================================
    // 1. FLOW FIELD CANVAS LOGIC
    // ==========================================
    const canvas = document.getElementById('flowfield-canvas');
    const ctx = canvas.getContext('2d');
    let gridNodes = [];
    let gridSpacing = 60;
    let pullRadius = 300;
    let acceleration = 0.18;
    let damping = 0.85;
    const pointerCoords = { x: 0, y: 0, active: false };

    function resizeCanvas() {
      const dpr = window.devicePixelRatio || 1;
      const width = window.innerWidth;
      const height = window.innerHeight;
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      canvas.style.width = width + "px";
      canvas.style.height = height + "px";
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      gridNodes = [];
      const cols = Math.ceil(width / gridSpacing) + 1;
      const rows = Math.ceil(height / gridSpacing) + 1;
      for (let i = 0; i < cols; i++) {
        for (let j = 0; j < rows; j++) {
          const x = i * gridSpacing;
          const y = j * gridSpacing;
          gridNodes.push({ x, y, homeX: x, homeY: y, vx: 0, vy: 0 });
        }
      }
    }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    window.addEventListener('mousemove', (e) => {
      pointerCoords.x = e.clientX;
      pointerCoords.y = e.clientY;
      pointerCoords.active = true;
    });
    document.addEventListener('mouseleave', () => { pointerCoords.active = false; });

    function runFlowfieldFrame() {
      ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
      ctx.strokeStyle = 'rgba(255, 255, 255, 0.035)';
      ctx.lineWidth = 1;

      const px = pointerCoords.x;
      const py = pointerCoords.y;
      const isPointerActive = pointerCoords.active;

      gridNodes.forEach((node) => {
        if (isPointerActive) {
          const dx = px - node.x;
          const dy = py - node.y;
          const distance = Math.sqrt(dx * dx + dy * dy);
          if (distance < pullRadius) {
            const pullForce = (pullRadius - distance) / pullRadius;
            const magnitude = pullForce * acceleration * 12;
            const heading = Math.atan2(dy, dx);
            node.vx += Math.cos(heading) * magnitude;
            node.vy += Math.sin(heading) * magnitude;
          }
        }
        const springForceX = node.homeX - node.x;
        const springForceY = node.homeY - node.y;
        node.vx += springForceX * 0.025;
        node.vy += springForceY * 0.025;
        node.vx *= damping;
        node.vy *= damping;
        node.x += node.vx;
        node.y += node.vy;
      });

      const cols = Math.ceil(window.innerWidth / gridSpacing) + 1;
      const rows = Math.ceil(window.innerHeight / gridSpacing) + 1;

      for (let i = 0; i < cols - 1; i++) {
        for (let j = 0; j < rows - 1; j++) {
          const index = i * rows + j;
          const rightNeighbor = (i + 1) * rows + j;
          const bottomNeighbor = i * rows + (j + 1);

          if (gridNodes[index] && gridNodes[rightNeighbor]) {
            ctx.beginPath();
            ctx.moveTo(gridNodes[index].x, gridNodes[index].y);
            ctx.lineTo(gridNodes[rightNeighbor].x, gridNodes[rightNeighbor].y);
            ctx.stroke();
          }
          if (gridNodes[index] && gridNodes[bottomNeighbor]) {
            ctx.beginPath();
            ctx.moveTo(gridNodes[index].x, gridNodes[index].y);
            ctx.lineTo(gridNodes[bottomNeighbor].x, gridNodes[bottomNeighbor].y);
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(runFlowfieldFrame);
    }
    requestAnimationFrame(runFlowfieldFrame);

    function updateFlowfieldParam(param, val) {
      if (param === 'spacing') {
        gridSpacing = parseInt(val);
        document.getElementById('val-spacing').innerText = val + 'px';
        resizeCanvas();
      } else if (param === 'radius') {
        pullRadius = parseInt(val);
        document.getElementById('val-radius').innerText = val + 'px';
      } else if (param === 'gravity') {
        acceleration = parseFloat(val);
        document.getElementById('val-gravity').innerText = val;
      } else if (param === 'damping') {
        damping = parseFloat(val);
        document.getElementById('val-damping').innerText = val;
      }
    }
    
    function resetFlowfieldGrid() {
      resizeCanvas();
    }

    // ==========================================
    // 2. KINETIC CURSOR LOGIC
    // ==========================================
    const ring = document.getElementById('custom-cursor-ring');
    const dot = document.getElementById('custom-cursor-dot');
    const currentPos = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
    const targetPos = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
    const previousTargetPos = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
    
    let cursorStretchMultiplier = 1.0;
    let cursorLagDuration = 0.3;
    let cursorRingColor = '#3b82f6';

    gsap.set(dot, { x: currentPos.x, y: currentPos.y });
    gsap.set(ring, { x: currentPos.x, y: currentPos.y });

    let updateRingX = gsap.quickTo(ring, 'x', { duration: cursorLagDuration, ease: 'power3.out' });
    let updateRingY = gsap.quickTo(ring, 'y', { duration: cursorLagDuration, ease: 'power3.out' });
    const updateDotX = gsap.quickTo(dot, 'x', { duration: 0.05, ease: 'power1.out' });
    const updateDotY = gsap.quickTo(dot, 'y', { duration: 0.05, ease: 'power1.out' });

    window.addEventListener('mousemove', (e) => {
      targetPos.x = e.clientX;
      targetPos.y = e.clientY;
      updateDotX(e.clientX);
      updateDotY(e.clientY);
    });

    gsap.ticker.add(() => {
      const dx = targetPos.x - currentPos.x;
      const dy = targetPos.y - currentPos.y;
      currentPos.x += dx * 0.12;
      currentPos.y += dy * 0.12;

      updateRingX(currentPos.x);
      updateRingY(currentPos.y);

      const vx = targetPos.x - previousTargetPos.x;
      const vy = targetPos.y - previousTargetPos.y;
      const mouseVelocity = Math.sqrt(vx * vx + vy * vy);
      const travelAngle = Math.atan2(vy, vx) * (180 / Math.PI);

      // Telemetry preview update
      const telV = document.getElementById('telemetry-v');
      const telA = document.getElementById('telemetry-a');
      if (telV && telA) {
        telV.innerText = mouseVelocity.toFixed(1);
        telA.innerText = travelAngle.toFixed(1) + '°';
      }

      if (mouseVelocity > 1.5) {
        const stretchAmount = Math.min(mouseVelocity * 0.012 * cursorStretchMultiplier, 0.65);
        const scaleX = 1 + stretchAmount;
        const scaleY = 1 - stretchAmount * 0.45;
        gsap.to(ring, {
          rotate: travelAngle,
          scaleX,
          scaleY,
          duration: 0.12,
          overwrite: 'auto',
        });
      } else {
        gsap.to(ring, {
          scaleX: 1,
          scaleY: 1,
          duration: 0.25,
          overwrite: 'auto',
        });
      }
      previousTargetPos.x = targetPos.x;
      previousTargetPos.y = targetPos.y;
    });

    function updateCursorParam(param, val) {
      if (param === 'stretch') {
        cursorStretchMultiplier = parseFloat(val);
        document.getElementById('val-c-stretch').innerText = val + 'x';
      } else if (param === 'duration') {
        cursorLagDuration = parseFloat(val);
        document.getElementById('val-c-duration').innerText = val + 's';
        
        // Rebuild gsap quickTo with new duration
        updateRingX = gsap.quickTo(ring, 'x', { duration: cursorLagDuration, ease: 'power3.out' });
        updateRingY = gsap.quickTo(ring, 'y', { duration: cursorLagDuration, ease: 'power3.out' });
      }
    }

    function updateCursorColor(hex) {
      cursorRingColor = hex;
      ring.style.borderColor = hex;
      dot.style.backgroundColor = hex;
    }

    // Bind link hovers
    function handlePointerEnter() {
      gsap.to(ring, { scale: 1.75, borderWidth: '1px', duration: 0.3, ease: 'power2.out' });
      gsap.to(dot, { scale: 0, duration: 0.15 });
    }
    function handlePointerLeave() {
      gsap.to(ring, { scale: 1, borderWidth: '1.5px', duration: 0.3, ease: 'power2.out' });
      gsap.to(dot, { scale: 1, duration: 0.15 });
    }
    function bindLinkHovers() {
      const hoverTargets = document.querySelectorAll('a, button, [role="button"], .interactive-node');
      hoverTargets.forEach((target) => {
        target.removeEventListener('mouseenter', handlePointerEnter);
        target.removeEventListener('mouseleave', handlePointerLeave);
        target.addEventListener('mouseenter', handlePointerEnter);
        target.addEventListener('mouseleave', handlePointerLeave);
      });
    }
    bindLinkHovers();

    // ==========================================
    // 3. SUBSTRATE REVEAL MASK LOGIC
    // ==========================================
    const heroBounds = document.getElementById('hero-bounds');
    const pathMask = document.getElementById('path-mask');
    let maskTargetRadius = 160;

    heroBounds.addEventListener('mousemove', (e) => {
      const area = heroBounds.getBoundingClientRect();
      const localX = e.clientX - area.left;
      const localY = e.clientY - area.top;
      gsap.to(pathMask, {
        attr: { cx: localX, cy: localY },
        duration: 0.15,
        ease: 'power2.out',
      });
    });

    heroBounds.addEventListener('mouseenter', () => {
      gsap.to(pathMask, {
        attr: { r: maskTargetRadius },
        duration: 0.6,
        ease: 'power3.out',
      });
    });

    heroBounds.addEventListener('mouseleave', () => {
      gsap.to(pathMask, {
        attr: { r: 0 },
        duration: 0.6,
        ease: 'power3.inOut',
      });
    });

    // Sandbox Preview Mask reveal
    const sbHero = document.getElementById('sandbox-hero');
    const sbPathMask = document.getElementById('sb-path-mask');
    
    sbHero.addEventListener('mousemove', (e) => {
      const area = sbHero.getBoundingClientRect();
      const localX = e.clientX - area.left;
      const localY = e.clientY - area.top;
      gsap.to(sbPathMask, {
        attr: { cx: localX, cy: localY },
        duration: 0.15,
        ease: 'power2.out',
      });
    });

    sbHero.addEventListener('mouseenter', () => {
      gsap.to(sbPathMask, {
        attr: { r: maskTargetRadius },
        duration: 0.6,
        ease: 'power3.out',
      });
    });

    sbHero.addEventListener('mouseleave', () => {
      gsap.to(sbPathMask, {
        attr: { r: 0 },
        duration: 0.6,
        ease: 'power3.inOut',
      });
    });

    function updateMaskParam(param, val) {
      if (param === 'radius') {
        maskTargetRadius = parseInt(val);
        document.getElementById('val-m-radius').innerText = val + 'px';
      }
    }

    // ==========================================
    // 4. BORDER BEAM LOGIC
    // ==========================================
    function updateBeamParam(param, val) {
      const beam = document.getElementById('sb-beam-trail');
      if (param === 'size') {
        beam.style.setProperty('--size', val + 'px');
        document.getElementById('val-b-size').innerText = val + 'px';
      } else if (param === 'duration') {
        beam.style.setProperty('--duration', val + 's');
        document.getElementById('val-b-duration').innerText = val + 's';
      }
    }

    function updateBeamColors(from, to) {
      const beam = document.getElementById('sb-beam-trail');
      beam.style.setProperty('--color-from', from);
      beam.style.setProperty('--color-to', to);
    }
  </script>
